<section id="proyectos" data-aos="fade-up"
     data-aos-duration="1000">
  <div class="container">
    <p class="section-label">Trabajo</p>
    <h2 class="section-title">Proyectos Destacados</h2>

    <div class="proj-grid">
      {proyectos.map((p,i) => (
        <div class="proj-card" data-aos="fade-up" data-aos-delay={i * 100}>

          <div class="img-carousel" data-total={p.imagenes.length}>
            <div class="img-track">
              {p.imagenes.map((src) => (
                <div class="img-slide">
                  <img src={src} alt={p.titulo} />
                </div>
              ))}
            </div>

            {p.imagenes.length > 1 && (
              <div class="carousel-nav">
                <button class="prev-btn" aria-label="Anterior">&#8249;</button>
                <button class="next-btn" aria-label="Siguiente">&#8250;</button>
              </div>
            )}

            <div class="img-dots">
              {p.imagenes.map((_, i) => (
                <div class={`img-dot ${i === 0 ? 'active' : ''}`} data-index={i}></div>
              ))}
            </div>
          </div>

          <div class="proj-body">
            <div class="proj-header">
              <p class="proj-title">{p.titulo}</p>
              <span class={`proj-badge ${p.badgeClass}`}>{p.badge}</span>
            </div>
            <p class="proj-desc">{p.descripcion}</p>
            <div class="proj-tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            <div class="proj-links">
              {p.demo && <a href={p.demo} target="_blank" class="btn-demo">Demo</a>}
              {p.repo && <a href={p.repo} target="_blank" class="btn-repo">GitHub</a>}
            </div>
          </div>

        </div>
      ))}
    </div>
  </div>

  <div class="lightbox-overlay" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">&times;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    </div>
</section>

<style>
  #proyectos { padding: 5rem 0; }

  .section-label {
    font-size: 12px;
    color: var(--c-orange);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 0.5rem;
  }

  .section-title {
    font-size: 22px;
    font-weight: 500;
    color: #F0F0F0;
    margin: 0 0 2rem;
  }

  .proj-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(300px, 100%), 1fr));
  gap: 16px;
}

  .proj-card {
    background: #1E1E1E;
    border: 0.5px solid #2E2E2E;
    border-radius: 12px;
    overflow: hidden;
  }

  /* Carrusel de imágenes */
  .img-carousel {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: #252525;
  }

  .img-track {
    display: flex;
    height: 100%;
    transition: transform 0.35s ease;
  }

  .img-slide {
    min-width: 100%;
    height: 100%;
    flex-shrink: 0;
  }

  .img-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-nav {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px;
    pointer-events: none;
  }

  .carousel-nav button {
    pointer-events: all;
    background: rgba(0,0,0,0.5);
    border: none;
    color: #fff;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-nav button:hover { background: var(--c-orange); }

  .img-dots {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 5px;
  }

  :global(.img-dot) {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    cursor: pointer;
  }

  :global(.img-dot.active) { background: var(--c-orange); }

  /* Body de la card */
  .proj-body { padding: 1rem 1.25rem; }

  .proj-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 6px;
    gap: 8px;
    flex-wrap: wrap;
  }

  .proj-title {
    font-size: 15px;
    font-weight: 500;
    color: #F0F0F0;
    margin: 0;
  }

  .proj-badge {
    font-size: 11px;
    border-radius: 99px;
    padding: 2px 9px;
    white-space: nowrap;
  }

  .badge-prod { background: rgba(30,180,100,0.12); color: #4ade80; border: 0.5px solid rgba(30,180,100,0.3); }
  .badge-wip { background: rgba(232,99,26,0.1); color: var(--c-orange); border: 0.5px solid rgba(232,99,26,0.3); }
  .badge-personal { background: #2A2A2A; color: var(--c-text-muted); border: 0.5px solid #333; }

  .proj-desc {
    font-size: 12px;
    color: #BEBEBE;
    line-height: 1.6;
    margin: 0 0 10px;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: 10px;
  }

  .tag {
    font-size: 11px;
    background: #2A2A2A;
    color: var(--c-text-muted);
    border-radius: 4px;
    padding: 2px 7px;
  }

  .proj-links { display: flex; gap: 8px; }

  .btn-demo {
    font-size: 12px;
    padding: 5px 12px;
    border-radius: 7px;
    background: var(--c-orange);
    color: #fff;
    text-decoration: none;
  }

  .btn-repo {
    font-size: 12px;
    padding: 5px 12px;
    border-radius: 7px;
    background: transparent;
    color: #BEBEBE;
    border: 0.5px solid #3A3A3A;
    text-decoration: none;
  }

  .btn-demo:hover { opacity: 0.85; }
  .btn-repo:hover { border-color: var(--c-orange); color: var(--c-orange); }


  /* Lightbox */
.lightbox-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(6px);
  z-index: 999;
  align-items: center;
  justify-content: center;
}

.lightbox-overlay.open {
  display: flex;
}

.lightbox-img {
  max-width: 90vw;
  max-height: 85vh;
  border-radius: 10px;
  object-fit: contain;
  box-shadow: 0 0 60px rgba(0,0,0,0.6);
  animation: lb-in 0.2s ease;
}

@keyframes lb-in {
  from { opacity: 0; transform: scale(0.95); }
  to   { opacity: 1; transform: scale(1); }
}

.lightbox-close {
  position: fixed;
  top: 20px;
  right: 24px;
  background: none;
  border: none;
  color: #fff;
  font-size: 28px;
  cursor: pointer;
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.15s;
}

.lightbox-close:hover { opacity: 1; color: var(--c-orange); }

</style>

<script>
  document.querySelectorAll('.img-carousel').forEach((carousel) => {
    const track = carousel.querySelector('.img-track') as HTMLElement;
    const dots = carousel.querySelectorAll('.img-dot');
    const total = parseInt(carousel.getAttribute('data-total') || '1');
    let cur = 0;

    function goTo(idx: number) {
      cur = idx;
      track.style.transform = `translateX(-${cur * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === cur));
    }

    carousel.querySelector('.prev-btn')?.addEventListener('click', () =>
      goTo(cur > 0 ? cur - 1 : total - 1));
    carousel.querySelector('.next-btn')?.addEventListener('click', () =>
      goTo(cur < total - 1 ? cur + 1 : 0));
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
  });


  // Lightbox
const overlay = document.getElementById('lightbox');
const lbImg   = document.getElementById('lightbox-img');

document.querySelectorAll('.img-slide img').forEach((img) => {
  img.style.cursor = 'zoom-in';
  img.addEventListener('click', () => {
    lbImg.src = (img as HTMLImageElement).src;
    lbImg.alt = (img as HTMLImageElement).alt;
    overlay!.classList.add('open');
  });
});

// Cerrar con botón, click en fondo o Escape
document.getElementById('lightbox-close')?.addEventListener('click', close);
overlay?.addEventListener('click', (e) => { if (e.target === overlay) close(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

function close() { overlay!.classList.remove('open'); }
</script>