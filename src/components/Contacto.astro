---
// Contact.astro
---

<section id="contacto" data-aos="fade-up" data-aos-delay={100}>
    
  <div class="container">
    
    <div>
        <p class="section-label">Contacto</p>
        <h2 class="section-title">Hablemos</h2>
    </div>
    <div class="contact-wrapper">
      <div class="contact-info">
        <p class="contact-desc">
          ¿Tienes un proyecto en mente o simplemente quieres saludar? 
          Escríbeme y te respondo lo antes posible.
        </p>
        <a href="mailto:tu@email.com" target="_blank" class="contact-email">cesar.m004@gmail.com</a>
        <br>
        <br>
        <a href="mailto:tu@email.com" target="_blank" class="linkedin">Linkedln</a>
      </div>

      <form id="contact-form">
        <input type="hidden" name="subject" value="Nuevo mensaje desde portfolio" />
        <input type="checkbox" name="botcheck" style="display:none" />

        <div class="form-group">
          <label for="name">Nombre</label>
          <input type="text" id="name" name="name" placeholder="Tu nombre" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="tu@email.com" required />
        </div>

        <div class="form-group">
          <label for="message">Mensaje</label>
          <textarea id="message" name="message" rows="5" placeholder="Cuéntame..." required></textarea>
        </div>

        <button type="submit" id="submit-btn">
          <span id="btn-text">Enviar mensaje</span>
          <span id="btn-loading" style="display:none">Enviando...</span>
        </button>

        <p id="form-success" style="display:none">✓ Mensaje enviado. ¡Te escribo pronto!</p>
        <p id="form-error" style="display:none">✗ Algo falló. Inténtalo de nuevo.</p>
      </form>
    </div>
  </div>
</section>

<style>
  #contacto { padding: 5rem 0; }

  .linkedin {
    box-sizing: border-box;
    font-size: 13px;
    color: var(--c-orange);
    border: 0.5px solid var(--c-orange);
    border-radius: 8px;
    padding: 6px 14px;
    text-decoration: none;
  }

  .linkedin:hover {
    background: var(--c-orange);
    color: #fff;
  }
  .linkedin img{
    width: 20px;
    padding-top: -20px;

  }
  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: start;
  }

  .container{
    background: #1E1E1E;
    border: 0.5px solid #2E2E2E;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    max-width: 850px;
  }
  .contact-desc {
    font-size: 14px;
    color: #BEBEBE;
    line-height: 1.7;
    margin: 0 0 1.25rem;
  }

  .contact-email {
    font-size: 13px;
    color: var(--c-orange);
    text-decoration: none;
    border-bottom: 0.5px solid rgba(232,99,26,0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .contact-email:hover { border-color: var(--c-orange); }

  /* Form */
  form { display: flex; flex-direction: column; gap: 14px; }

  .form-group { display: flex; flex-direction: column; gap: 5px; }

  label {
    font-size: 12px;
    color: #888;
    letter-spacing: 0.05em;
  }

  input, textarea {
    background: #1E1E1E;
    border: 0.5px solid #2E2E2E;
    border-radius: 8px;
    padding: 10px 14px;
    color: #F0F0F0;
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
    resize: none;
    font-family: inherit;
  }

  input:focus, textarea:focus { border-color: var(--c-orange); }

  button[type="submit"] {
    margin-top: 4px;
    background: var(--c-orange);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 11px 20px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  button[type="submit"]:hover { opacity: 0.85; }
  button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }

  #form-success { font-size: 13px; color: #4ade80; margin: 0; }
  #form-error   { font-size: 13px; color: #f87171; margin: 0; }

  @media (max-width: 640px) {
    .contact-wrapper { grid-template-columns: 1fr; gap: 2rem; }
  }

  .section-label {
    font-size: 12px;
    color: var(--c-orange);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 0.5rem;
  }

  .section-title {
    font-size: 22px;
    font-weight: 500;
    color: #F0F0F0;
    margin: 0 0 2.5rem;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text')!;
  const btnLoading = document.getElementById('btn-loading')!;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline';
    successMsg.style.display = 'none';
    errorMsg.style.display = 'none';

    const formData = new FormData(form);
    formData.append("access_key", "d8d4ddc0-7a88-48d9-9bdd-05ac3a4a8572");

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData
      });

      const data = await response.json();
      console.log(data);

      if (response.ok) {
        successMsg.style.display = 'block';
        form.reset();
      } else {
        errorMsg.style.display = 'block';
        console.error(data.message);
      }
    } catch {
      errorMsg.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    }
  });
</script>