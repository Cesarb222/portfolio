<style>
  #experiencia {
    padding: 5rem 0;
  }

  .section-label {
    font-size: 12px;
    color: var(--c-orange);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 0.5rem;
  }

  .section-title {
    font-size: 22px;
    font-weight: 500;
    color: #F0F0F0;
    margin: 0 0 2.5rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    position: relative;
    padding-left: 28px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: #2E2E2E;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 2rem;
  }

  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: -25px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--c-orange);
    border: 2px solid #141414;
  }

  .exp-card {
    background: #1E1E1E;
    border: 0.5px solid #2E2E2E;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 6px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .exp-company {
    font-size: 15px;
    font-weight: 500;
    color: #F0F0F0;
    margin: 0;
  }

  .exp-date {
    font-size: 12px;
    color: var(--c-orange);
    background: rgba(232,99,26,0.1);
    border: 0.5px solid rgba(232,99,26,0.3);
    border-radius: 99px;
    padding: 3px 10px;
    white-space: nowrap;
  }

  .exp-role {
    font-size: 13px;
    color: var(--c-text-muted);
    margin: 0 0 12px;
  }

  .exp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .exp-list li {
    font-size: 13px;
    color: #BEBEBE;
    line-height: 1.6;
    padding-left: 14px;
    position: relative;
  }

  .exp-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--c-orange);
    font-size: 11px;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 0.5px solid #2A2A2A;
  }

  .tag {
    font-size: 11px;
    background: #2A2A2A;
    color: var(--c-text-muted);
    border-radius: 4px;
    padding: 3px 8px;
  }
</style>