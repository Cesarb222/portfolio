<style>
  .nav-wrapper {
    background: #181818;
    border-bottom: 0.5px solid #2E2E2E;
    padding: 0 1.5rem; /* Reducido un poco para dar más aire en móviles */
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-logo {
    font-size: 15px;
    font-weight: 500;
    color: #F0F0F0;
    text-decoration: none;
    white-space: nowrap; /* Evita que el logo se rompa en dos líneas */
  }

  .nav-logo span { color: var(--c-orange); }

  /* 📱 CONFIGURACIÓN BASE PARA MÓVILES */
  .nav-links {
    display: none; /* Oculta la lista de enlaces por defecto en pantallas pequeñas */
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-size: 14px;
    color: var(--c-text-muted);
    text-decoration: none;
    transition: color 0.2s ease; /* Transición suave al pasar el ratón */
  }

  .nav-links a:hover { color: var(--c-orange); }

  .nav-cv {
    font-size: 13px;
    color: var(--c-orange);
    border: 0.5px solid var(--c-orange);
    border-radius: 8px;
    padding: 6px 14px;
    text-decoration: none;
    white-space: nowrap; /* Evita que el texto CV se divida */
    transition: all 0.2s ease;
  }

  .nav-cv:hover {
    background: var(--c-orange);
    color: #fff;
  }

  /* 💻 PANTALLAS GRANDES (A partir de tablets y ordenadores) */
  @media (min-width: 768px) {
    .nav-wrapper {
      padding: 0 2rem; /* Recupera el espaciado original en pantallas grandes */
    }
    
    .nav-links {
      display: flex; /* Muestra los enlaces en horizontal solo en ordenadores */
    }
  }
</style>
