---
---

<section id="skills" data-aos="fade-up"
     data-aos-duration="1000">
  <div class="container">
    <p class="section-label">Tecnologías</p>
    <h2 class="section-title">Stack & habilidades</h2>

    <div class="skills-grid">

      <div class="skill-card" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">Frontend</span>
        </div>
        <div class="tags">
          <span class="tag">HTML5</span>
          <span class="tag">CSS3</span>
          <span class="tag">JavaScript</span>
          <span class="tag">Bootstrap</span>
          <span class="tag">Astro</span>
        </div>
      </div>

      <div class="skill-card" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">Backend</span>
        </div>
        <div class="tags">
          <span class="tag">Java</span>
          <span class="tag">Spring Boot</span>
          <span class="tag">Python</span>
          <span class="tag">py4web</span>
          <span class="tag">Node.js</span>
          <span class="tag">Express</span>
          <span class="tag">PHP</span>
          <span class="tag">Symfony</span>
        </div>
      </div>

      <div class="skill-card" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">Bases de datos</span>
        </div>
        <div class="tags">
          <span class="tag">PostgreSQL</span>
          <span class="tag">MySQL</span>
          <span class="tag">Firebase</span>
          <span class="tag">MongoDB</span>
          <span class="tag">Hibernate</span>
          <span class="tag">Doctrine</span>
        </div>
      </div>

      <div class="skill-card" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">Aplicaciones</span>
        </div>
        <div class="tags">
          <span class="tag">Android</span>
          <span class="tag">Jetpack Compose</span>
          <span class="tag">Kotlin</span>
          <span class="tag">C#</span>
          <span class="tag">WPF</span>
          <span class="tag">.NET Framework</span>
        </div>
      </div>

      <div class="skill-card" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">Herramientas</span>
        </div>
        <div class="tags">
          <span class="tag">Git</span>
          <span class="tag">GitHub</span>
          <span class="tag">Azure DevOps</span>
          <span class="tag">MVC</span>
          <span class="tag">MVVM</span>
          <span class="tag">Registry</span>
        </div>
      </div>

      <div class="skill-card" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">Patrones/Arquitecturas</span>
        </div>
        <div class="tags">
          <span class="tag">Por capas</span>
          <span class="tag">MVC</span>
          <span class="tag">MVVM</span>
          <span class="tag">Registry</span>
        </div>
      </div>

    </div>

    <span class="bi-label" >Explorando · Data & Business Intelligence</span >

    <div class="skills-grid" data-aos="fade-up"
     data-aos-duration="1000">

      <div class="skill-card skill-card-bi" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">ETL & Reporting</span>
        </div>
        <div class="tags">
          <span class="tag-bi">Pentaho</span>
          <span class="tag-bi">ETL pipelines</span>
          <span class="tag-bi">Informes BI</span>
        </div>
      </div>

      <div class="skill-card skill-card-bi" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">SQL avanzado</span>
        </div>
        <div class="tags">
          <span class="tag-bi">Vistas SQL</span>
          <span class="tag-bi">Procedures</span>
          <span class="tag-bi">Subconsultas</span>
          <span class="tag-bi">PostgreSQL</span>
          <span class="tag-bi">SQL</span>
          <span class="tag-bi">SQL Server</span>
        </div>
      </div>

      <div class="skill-card skill-card-bi" data-aos="fade-up"
     data-aos-duration="1000">
        <div class="card-header">
          <span class="card-title">Entorno empresarial</span>
        </div>
        <div class="tags">
          <span class="tag-bi">Azure DevOps</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  #skills {
    padding: 5rem 0;
  }

  .section-label {
    font-size: 12px;
    color: var(--c-orange);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 0.5rem;
  }

  .section-title {
    font-size: 22px;
    font-weight: 500;
    color: #F0F0F0;
    margin: 0 0 2.5rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
    margin-bottom: 12px;
  }

  .skill-card {
    background: #1E1E1E;
    border: 0.5px solid #2E2E2E;
    border-radius: 12px;
    padding: 1.25rem;
  }

  .skill-card-bi {
    border-color: rgba(232,99,26,0.4);
  }

  .card-header {
    margin-bottom: 14px;
  }

  .card-title {
    font-size: 13px;
    font-weight: 500;
    color: #F0F0F0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 11px;
    background: #2A2A2A;
    color: var(--c-text-muted);
    border-radius: 4px;
    padding: 3px 8px;
  }

  .tag-bi {
    font-size: 11px;
    background: rgba(232,99,26,0.1);
    color: var(--c-orange);
    border: 0.5px solid rgba(232,99,26,0.3);
    border-radius: 4px;
    padding: 3px 8px;
  }

  .bi-label {
    font-size: 11px;
    color: var(--c-orange);
    background: rgba(232,99,26,0.1);
    border: 0.5px solid rgba(232,99,26,0.3);
    border-radius: 99px;
    padding: 3px 10px;
    display: inline-block;
    margin-bottom: 1rem;
    margin-top: 1.5rem;
  }
</style>